@model Orders
@{
    Layout = null;
}
<link href="@("http://" + Context.Request.Host.ToString() + "/StyleSheet.css")" rel="stylesheet" />
<h1>Orders</h1>
<table class="table w-100 mt">
    <thead>
        <tr>
            <th>Date And Time Of Order</th>
            <th>Stock Name</th>
            <th>Order Type</th>
            <th>Quantity</th>
            <th>Price</th>
            <th>TradeAmount</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.SellOrders != null)
        {
            @foreach (SellOrderResponse sellOrder in Model.SellOrders)
            {
                <tr>
                    <td style="width: 15%">@sellOrder.DateAndTimeOfOrder</td>
                    <td style="width: 20%">@sellOrder.StockName</td>
                    <td style="width: 13%">Sell Order</td>
                    <td style="width: 9%">@sellOrder.Quantity</td>
                    <td style="width: 9%">@sellOrder.Price</td>
                    <td style="width: 10%">@sellOrder.TradeAmount</td>
                </tr>
            }
        }
        @if(Model.BuyOrders != null){
            @foreach (BuyOrderResponse buyOrder in Model.BuyOrders)
            {
                <tr>
                    <td style="width: 15%">@buyOrder.DateAndTimeOfOrder</td>
                    <td style="width: 20%">@buyOrder.StockName</td>
                    <td style="width: 13%">Buy Order</td>
                    <td style="width: 9%">@buyOrder.Quantity</td>
                    <td style="width: 9%">@buyOrder.Price</td>
                    <td style="width: 10%">@buyOrder.TradeAmount</td>
                </tr>
            }
        }
    </tbody>
</table>

